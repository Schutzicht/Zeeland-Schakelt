---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Plek">
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/aanbod" class="inline-flex items-center gap-1.5 text-sm font-semibold text-sea-600 transition hover:text-sea-700">
      <Icon name="arrowLeft" size={17} /> Terug naar het aanbod
    </a>

    <div id="zs-detail" class="mt-5"></div>

    <div id="zs-notfound" class="hidden rounded-2xl border border-dashed border-ink/15 bg-white p-12 text-center">
      <span class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-sea-50 text-sea-500">
        <Icon name="info" size={24} />
      </span>
      <h1 class="mt-3 font-display text-xl font-bold text-ink">Deze plek bestaat niet (meer)</h1>
      <p class="mx-auto mt-1 max-w-sm text-sm text-mist">
        Misschien is het aanbod verlopen of is de link niet compleet. Bekijk het volledige aanbod om verder te zoeken.
      </p>
      <a href="/aanbod" class="mt-5 inline-flex items-center gap-1.5 rounded-xl bg-sea-600 px-5 py-2.5 text-sm font-semibold text-white">
        Naar het aanbod
      </a>
    </div>
  </div>
</Base>

<script>
  import '../scripts/detail';
</script>
