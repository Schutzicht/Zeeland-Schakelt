---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { SEED_LISTINGS } from '../../data/listings';

const seedCount = SEED_LISTINGS.length;

const tabs = [
  { id: 'wachtrij', label: 'Wachtrij' },
  { id: 'goedgekeurd', label: 'Goedgekeurd' },
  { id: 'afgewezen', label: 'Afgewezen' },
  { id: 'alle', label: 'Alle inzendingen' },
];
---

<Base title="Beheer" description="Beheeromgeving voor moderatie van het aanbod op Zeeland Schakelt.">
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Kop -->
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-sea-50 px-3 py-1 text-sm font-semibold text-sea-700">
          <Icon name="shield" size={16} /> Beheeromgeving
        </span>
        <h1 class="mt-3 font-display text-3xl font-extrabold text-ink">Moderatie & contentbeheer</h1>
        <p class="mt-1 text-mist">Keur ingezonden aanbod goed of af voordat het zichtbaar wordt.</p>
      </div>
      <button
        id="zs-reset-demo"
        type="button"
        class="inline-flex items-center gap-1.5 rounded-lg border border-ink/15 px-3 py-2 text-sm font-medium text-mist transition hover:border-coral-400 hover:text-coral-600"
      >
        <Icon name="refresh" size={16} /> Demo resetten
      </button>
    </div>

    <!-- Demo-melding -->
    <div class="mt-5 flex items-start gap-3 rounded-xl border border-sea-200 bg-foam p-4 text-sm text-ink-soft">
      <span class="mt-0.5 text-sea-500"><Icon name="info" size={18} /></span>
      <p>
        Demo-omgeving. In productie zit deze pagina achter een login. Ingezonden aanbod wordt nu lokaal in deze browser
        bewaard. Naast de inzendingen hieronder staan er {seedCount} vaste voorbeeldplekken altijd live.
      </p>
    </div>

    <!-- Stats -->
    <div id="zs-stats" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4"></div>

    <!-- Tabs -->
    <div class="no-scrollbar mt-8 flex gap-1 overflow-x-auto border-b border-ink/10">
      {
        tabs.map((t, i) => (
          <button
            type="button"
            data-tab={t.id}
            class:list={[
              'zs-tab shrink-0 border-b-2 px-4 py-2.5 text-sm font-semibold transition',
              i === 0 ? 'border-sea-600 text-sea-700' : 'border-transparent text-mist hover:text-ink',
            ]}
          >
            {t.label}
            <span data-tabcount={t.id} class="ml-1 rounded-full bg-sea-50 px-1.5 py-0.5 text-xs text-sea-700"></span>
          </button>
        ))
      }
    </div>

    <!-- Lijst -->
    <div id="zs-admin-list" class="mt-6 space-y-4"></div>

    <!-- Lege staat -->
    <div id="zs-admin-empty" class="hidden rounded-2xl border border-dashed border-ink/15 bg-white p-12 text-center">
      <span class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-sea-50 text-sea-500">
        <Icon name="building" size={24} />
      </span>
      <h3 class="mt-3 font-display text-lg font-bold text-ink">Niets in deze lijst</h3>
      <p class="mx-auto mt-1 max-w-sm text-sm text-mist">
        Plaats een aanbod via het formulier om de moderatie-flow te testen.
      </p>
      <a href="/plaatsen" class="mt-4 inline-flex items-center gap-1.5 rounded-xl bg-sea-600 px-5 py-2.5 text-sm font-semibold text-white">
        <Icon name="plus" size={16} stroke={2.2} /> Naar het formulier
      </a>
    </div>
  </div>
</Base>

<script>
  import '../../scripts/beheer';
</script>
