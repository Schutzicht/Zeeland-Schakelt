---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';

const channels = [
  {
    icon: 'desk',
    name: 'Werken',
    color: '#155f9c',
    tint: '#eaf4fb',
    text: 'Vraag en aanbod van werkplekken en ruimtes. Zoek je een flexplek voor je team of heb je er een over? Hier kom je samen.',
  },
  {
    icon: 'bed',
    name: 'Overnachten',
    color: '#7a4bd0',
    tint: '#f0eafb',
    text: 'Voor wie een paar nachten aan de juiste kant van de tunnel wil blijven. Deel kamers, arrangementen en tips.',
  },
  {
    icon: 'car',
    name: 'Carpoolen',
    color: '#e9522f',
    tint: '#fdeee8',
    text: 'Reis slim samen. Bied je rit aan of zoek een meerijder, stem af op het veer en de shuttle, en deel de kosten.',
  },
];

const rules = [
  'Wees duidelijk: vertel kort wat je zoekt of aanbiedt, met plaats en tijd.',
  'Reageer rechtstreeks op elkaar en maak afspraken in een privébericht.',
  'Houd het netjes en respectvol. Geen spam of commerciële reclame.',
  'Plek of rit gevonden? Laat het weten, dan blijft het kanaal overzichtelijk.',
];
---

<Base
  title="Community"
  description="Doe mee met de WhatsApp-community van Zeeland Schakelt. Drie kanalen: Werken, Overnachten en Carpoolen. Vraag en aanbod vinden elkaar razendsnel."
>
  <!-- Hero -->
  <section class="relative overflow-hidden text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-aqua-600 to-sea-700"></div>
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image:url('/images/zeeland-schakelt/generated/hero-community.png')"
    >
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-sea-900/80 via-sea-800/55 to-aqua-700/55"></div>
    <div class="relative mx-auto max-w-4xl px-4 pb-32 pt-24 text-center sm:px-6 sm:pb-36 sm:pt-28 lg:px-8">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-3.5 py-1.5 text-sm font-medium ring-1 ring-white/20">
        <Icon name="whatsapp" size={16} /> WhatsApp-community
      </span>
      <h1 class="mt-5 font-display text-3xl font-extrabold sm:text-4xl lg:text-5xl">Samen kom je verder</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/85">
        Het platform laat je het aanbod zien. In de community vind je elkaar. Zoek je iets specifieks of wil je je rit
        delen? Stel je vraag in het kanaal dat bij je past.
      </p>
    </div>
  </section>

  <!-- Kanalen -->
  <section class="relative z-10 mx-auto -mt-16 max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-5 sm:grid-cols-3">
      {
        channels.map((c) => (
          <div class="flex flex-col rounded-2xl bg-white p-6 shadow-card ring-1 ring-ink/5">
            <span class="grid h-12 w-12 place-items-center rounded-xl" style={`background:${c.tint};color:${c.color}`}>
              <Icon name={c.icon} size={24} />
            </span>
            <h2 class="mt-4 font-display text-xl font-bold text-ink">{c.name}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-mist">{c.text}</p>
            <a
              href="#"
              class="mt-5 inline-flex items-center justify-center gap-2 rounded-xl bg-aqua-500 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-aqua-600"
            >
              <Icon name="whatsapp" size={17} /> Doe mee
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Ik zoek / ik bied -->
  <section class="mx-auto mt-20 max-w-5xl px-4 sm:px-6 lg:mt-24 lg:px-8">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="rounded-2xl border border-ink/10 bg-white p-7 shadow-card">
        <span class="grid h-11 w-11 place-items-center rounded-xl bg-sea-50 text-sea-600"><Icon name="search" size={22} /></span>
        <h3 class="mt-4 font-display text-lg font-bold text-ink">Ik zoek iets</h3>
        <p class="mt-2 text-sm text-mist">
          Vind je niet wat je zoekt in het aanbod? Plaats je vraag in de community. Vaak weet iemand precies de juiste
          plek of een meerijder.
        </p>
        <a href="#" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-aqua-600 hover:text-aqua-700">
          Stel je vraag <Icon name="arrowRight" size={15} />
        </a>
      </div>
      <div class="rounded-2xl border border-ink/10 bg-white p-7 shadow-card">
        <span class="grid h-11 w-11 place-items-center rounded-xl bg-coral-500/12 text-coral-600"><Icon name="hand" size={22} /></span>
        <h3 class="mt-4 font-display text-lg font-bold text-ink">Ik bied iets aan</h3>
        <p class="mt-2 text-sm text-mist">
          Heb je structureel iets aan te bieden? Zet het op het platform, dan vindt heel Zeeland het terug op de kaart en
          in de lijst.
        </p>
        <a href="/plaatsen" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-coral-600 hover:text-coral-700">
          Plaats jouw aanbod <Icon name="arrowRight" size={15} />
        </a>
      </div>
    </div>
  </section>

  <!-- Spelregels -->
  <section class="mx-auto mt-20 max-w-3xl px-4 sm:px-6 lg:mt-24 lg:px-8">
    <div class="rounded-3xl bg-foam p-8 sm:p-10">
      <h2 class="font-display text-xl font-extrabold text-ink">Zo houden we het fijn</h2>
      <ul class="mt-5 space-y-3">
        {
          rules.map((r) => (
            <li class="flex items-start gap-3 text-ink-soft">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md bg-aqua-500/15 text-aqua-600">
                <Icon name="check" size={15} stroke={2.4} />
              </span>
              <span class="text-sm leading-relaxed">{r}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-6 flex items-center gap-2 text-sm text-mist">
        <Icon name="checkCircle" size={17} class="text-aqua-600" /> Geen account nodig, gewoon meedoen via WhatsApp.
      </p>
    </div>
  </section>
</Base>
