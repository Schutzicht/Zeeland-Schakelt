---
import Logo from './Logo.astro';
import Icon from './Icon.astro';

const year = new Date().getFullYear();

const partners = [
  { src: '/images/partners/provincie-zeeland.svg', alt: 'Provincie Zeeland', h: 'h-9 sm:h-11' },
  { src: '/images/partners/dockwize.svg', alt: 'Dockwize', h: 'h-8 sm:h-10' },
  { src: '/images/partners/co3-campus.png', alt: 'CO3 Campus', h: 'h-8 sm:h-10' },
];
---

<footer class="relative">
  <!-- kleurrijke accent-rand -->
  <div class="h-1 w-full bg-gradient-to-r from-sea-500 via-aqua-400 to-coral-500"></div>

  <div class="bg-gradient-to-b from-white to-foam">
    <!-- PARTNERS -->
    <section class="mx-auto max-w-6xl px-4 pt-14 sm:px-6 lg:px-8 lg:pt-16">
      <p class="zs-eyebrow is-center mx-auto w-fit justify-center">Een initiatief van</p>
      <div class="mt-7 rounded-3xl bg-white p-7 shadow-card ring-1 ring-ink/[0.05] sm:p-9">
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-7 sm:gap-x-16">
          {
            partners.map((p, i) => (
              <>
                {i > 0 && <span class="hidden h-10 w-px bg-ink/10 sm:block"></span>}
                <img src={p.src} alt={p.alt} loading="lazy" class={`${p.h} w-auto`} />
              </>
            ))
          }
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-mist">
        Samen met de werkgroep mobiliteit Zeeland.
        <a href="/plaatsen" class="font-semibold text-sea-600 transition hover:text-sea-700">Word partner &rarr;</a>
      </p>
    </section>

    <!-- HOOFD-FOOTER -->
    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <Logo />
          <p class="mt-5 max-w-xs text-sm leading-relaxed text-mist">
            Het platform dat vraag en aanbod rond werken, reizen en verblijven in Zeeland samenbrengt tijdens de
            afsluiting van de Westerscheldetunnel.
          </p>
        </div>

        <div>
          <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-mist">Platform</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li><a href="/aanbod" class="font-medium text-ink-soft transition hover:text-sea-700">Bekijk aanbod</a></li>
            <li><a href="/plaatsen" class="font-medium text-ink-soft transition hover:text-sea-700">Plaats jouw aanbod</a></li>
            <li><a href="/community" class="font-medium text-ink-soft transition hover:text-sea-700">WhatsApp-community</a></li>
            <li><a href="/over" class="font-medium text-ink-soft transition hover:text-sea-700">Hoe het werkt</a></li>
          </ul>
        </div>

        <div>
          <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-mist">Tunnelafsluiting</h3>
          <div class="mt-4 rounded-2xl bg-sea-50 p-4 ring-1 ring-sea-100">
            <div class="flex items-center gap-2 text-xs text-sea-600">
              <span class="zs-dot h-1.5 w-1.5 rounded-full bg-aqua-500"></span>
              <span class="font-mono font-semibold uppercase tracking-wider">Live</span>
            </div>
            <p class="mt-2 font-display text-lg font-bold text-ink">jan t/m apr 2027</p>
            <p class="mt-1 text-sm text-mist">Westerscheldetunnel volledig afgesloten.</p>
          </div>
        </div>

        <div>
          <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-mist">Beheer</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li>
              <a href="/beheer" class="inline-flex items-center gap-1.5 font-medium text-ink-soft transition hover:text-sea-700">
                <Icon name="shield" size={15} /> Beheeromgeving
              </a>
            </li>
          </ul>
          <a
            href="/plaatsen"
            class="zs-btn-primary mt-5 inline-flex items-center gap-1.5 rounded-xl bg-coral-500 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-coral-600"
          >
            <Icon name="plus" size={16} stroke={2.2} /> Plaats aanbod
          </a>
        </div>
      </div>

      <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-ink/10 pt-6 text-xs text-mist sm:flex-row sm:items-center">
        <p>&copy; {year} Zeeland Schakelt. Een platform van Provincie Zeeland, Dockwize en CO3 Campus.</p>
        <p class="font-mono">Ontwikkeld door Agensea</p>
      </div>
    </div>
  </div>
</footer>
