---
// Hero-onderkant = interactieve tunnel-bouwtijdlijn (1 jan - 1 mei 2027, 120 dagen).
// Bouwvakker volgt de golf-curve; live dag/%-label; sleepbaar om te scrubben;
// kraan + stofwolk + mijlpaal-vlaggetjes; heropening-feest (auto + confetti) bij 100%.
const CREST = 'M0 62 C 320 33, 560 36, 760 57 S 1180 90, 1440 57';
const months = [
  { label: 'jan', left: 2 },
  { label: 'feb', left: 26.5 },
  { label: 'mrt', left: 51 },
  { label: 'apr', left: 75.5 },
  { label: 'mei', left: 98 },
];
const milestones = [
  { frac: 0.25, title: 'Fase 1 afgerond' },
  { frac: 0.5, title: 'Halverwege' },
  { frac: 0.85, title: 'Oplevering in zicht' },
];
---

<div class="zs-build pointer-events-none absolute inset-x-0 bottom-0 h-[130px]">
  <svg
    class="zs-build-svg pointer-events-none absolute bottom-0 left-0 h-[130px] w-full"
    viewBox="0 0 1440 130"
    fill="none"
    preserveAspectRatio="none"
    aria-hidden="true"
    style="filter:drop-shadow(0 8px 18px rgba(18,130,176,0.22))"
  >
    <defs>
      <linearGradient id="zsBuildGrad" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#114c7f"></stop>
        <stop offset="0.5" stop-color="#2479ba"></stop>
        <stop offset="1" stop-color="#2ed3c9"></stop>
      </linearGradient>
    </defs>
    <path d={`${CREST} L1440 130 L0 130 Z`} fill="#f6f1e6"></path>
    <path d={CREST} stroke="#bcd7ee" stroke-width="20" stroke-linecap="round"></path>
    <path
      class="zs-built"
      d={CREST}
      stroke="url(#zsBuildGrad)"
      stroke-width="20"
      stroke-linecap="round"
      pathLength="100"
      stroke-dasharray="100"
      stroke-dashoffset="100"
    ></path>
  </svg>

  <!-- kraan bij de overkant -->
  <div class="zs-crane pointer-events-none absolute" style="right:3.5%;bottom:70px">
    <svg width="54" height="60" viewBox="0 0 54 60" fill="none" aria-hidden="true">
      <rect x="22" y="10" width="4" height="48" fill="#114c7f"></rect>
      <path d="M24 10 L8 18 L24 18 Z" fill="#114c7f" opacity="0.35"></path>
      <rect x="6" y="9" width="44" height="4" rx="2" fill="#2479ba"></rect>
      <rect x="22" y="5" width="4" height="6" fill="#e9522f"></rect>
      <g class="zs-hook">
        <line x1="44" y1="13" x2="44" y2="26" stroke="#0b2436" stroke-width="1.4"></line>
        <rect x="41" y="26" width="6" height="4" rx="1" fill="#fb6b49"></rect>
      </g>
    </svg>
  </div>

  <!-- mijlpaal-vlaggetjes -->
  {
    milestones.map((m) => (
      <div class="zs-flag pointer-events-none absolute" data-frac={m.frac} title={m.title} style="left:25%;bottom:80px;transform:translate(-50%,0)">
        <svg width="16" height="22" viewBox="0 0 16 22" fill="none" aria-hidden="true">
          <rect class="zs-flag-pole" x="2" y="2" width="2" height="19" rx="1" fill="#9aa6b0"></rect>
          <path class="zs-flag-cloth" d="M4 3h9l-2.5 3.2L13 9.5H4z" fill="#9aa6b0"></path>
        </svg>
      </div>
    ))
  }

  <!-- oever-knopen -->
  <span class="zs-shore-start pointer-events-none absolute h-4 w-4 rounded-full bg-sea-700 ring-4 ring-cream" style="left:1.5%;bottom:78px;transform:translate(-50%,50%)"></span>
  <span class="zs-shore-end pointer-events-none absolute h-4 w-4 rounded-full bg-ink/30 ring-4 ring-cream" style="left:98.5%;bottom:84px;transform:translate(-50%,50%)"></span>

  <!-- maand-labels -->
  {
    months.map((m) => (
      <span class="pointer-events-none absolute font-mono text-[11px] font-semibold text-mist" style={`left:${m.left}%;bottom:16px;transform:translateX(-50%)`}>
        {m.label}
      </span>
    ))
  }

  <!-- vierende auto -->
  <div class="zs-car pointer-events-none absolute" style="left:-8%;bottom:74px">
    <svg width="40" height="22" viewBox="0 0 40 22" fill="none" aria-hidden="true">
      <path d="M3 14l3-7a3 3 0 0 1 2.7-1.7h14.6A3 3 0 0 1 28 6l4 4 5 1a2 2 0 0 1 2 2v3H3z" fill="#fb6b49"></path>
      <path d="M9 7h8v4H7z" fill="#bfe3ff" opacity="0.9"></path>
      <circle cx="12" cy="17" r="3" fill="#0b2436"></circle>
      <circle cx="30" cy="17" r="3" fill="#0b2436"></circle>
    </svg>
  </div>

  <!-- heropend-pop -->
  <div class="zs-reopen pointer-events-none absolute" style="right:2%;bottom:98px">
    <span class="inline-flex items-center gap-1 rounded-full bg-aqua-500 px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-wider text-white shadow-md">Heropend!</span>
  </div>

  <!-- confetti-laag -->
  <div class="zs-confetti pointer-events-none absolute inset-0"></div>

  <!-- opbouwende file achter de werkzaamheden -->
  <div class="zs-queue pointer-events-none absolute inset-0">
    {
      Array.from({ length: 14 }).map(() => (
        <div class="zs-qcar absolute" style="opacity:0;left:0;bottom:0">
          <span class="zs-smoke"></span>
          <svg width="26" height="15" viewBox="0 0 40 22" fill="none" aria-hidden="true">
            <path d="M3 14l3-7a3 3 0 0 1 2.7-1.7h14.6A3 3 0 0 1 28 6l4 4 5 1a2 2 0 0 1 2 2v3H3z" fill="currentColor"></path>
            <path d="M9 7h8v4H7z" fill="#bfe3ff" opacity="0.85"></path>
            <circle cx="12" cy="17" r="3" fill="#0b2436"></circle>
            <circle cx="30" cy="17" r="3" fill="#0b2436"></circle>
          </svg>
        </div>
      ))
    }
  </div>

  <!-- bouwvakker (volgt de curve) + label + stof -->
  <div class="zs-worker pointer-events-none absolute" style="left:1.5%;bottom:72px">
    <span class="zs-daylabel absolute bottom-[60px] left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-white px-2 py-[3px] font-mono text-[10px] font-semibold text-ink shadow-sm ring-1 ring-ink/10">Dag 0 / 120</span>
    <div class="zs-dust absolute bottom-1 left-0">
      <span></span><span></span><span></span>
    </div>
    <div class="zs-worker-bob">
      <svg width="58" height="68" viewBox="0 0 50 56" fill="none" aria-hidden="true">
        <ellipse cx="24" cy="54" rx="14" ry="2.6" fill="#0b2436" opacity="0.14"></ellipse>
        <g>
          <path d="M31 54l2.6-3 2.6 3z" fill="#8a96a1"></path>
          <circle cx="39.5" cy="52.6" r="2.3" fill="#76828e"></circle>
          <path d="M42.5 54l2.4-2.3 2.4 2.3z" fill="#aab4bd"></path>
          <rect x="28.2" y="51.4" width="3" height="3" rx="0.8" fill="#94a0ab"></rect>
          <circle cx="35.5" cy="53.4" r="1.4" fill="#aab4bd"></circle>
        </g>
        <rect x="18" y="38" width="5" height="13" rx="2.5" fill="#114c7f"></rect>
        <rect x="25" y="38" width="5" height="13" rx="2.5" fill="#114c7f"></rect>
        <path d="M15.5 49H24v3a1 1 0 0 1-1 1h-6.5a1 1 0 0 1-1-1z" fill="#0b2436"></path>
        <path d="M24 49h8.5v3a1 1 0 0 1-1 1H25a1 1 0 0 1-1-1z" fill="#0b2436"></path>
        <rect x="15" y="22" width="18" height="19" rx="6" fill="#2479ba"></rect>
        <rect x="21" y="22" width="6" height="19" fill="#2ed3c9"></rect>
        <circle cx="24" cy="15" r="6.2" fill="#f2c6a0"></circle>
        <path d="M15.5 13a8.5 8.5 0 0 1 17 0Z" fill="#fb6b49"></path>
        <rect x="13.5" y="11.6" width="21" height="3.2" rx="1.6" fill="#e9522f"></rect>
        <rect x="23" y="5.6" width="2" height="3" rx="1" fill="#e9522f"></rect>
        <g class="zs-arm">
          <rect x="30" y="25" width="10" height="4.5" rx="2.25" fill="#f2c6a0"></rect>
          <rect x="38.5" y="13.5" width="3.4" height="15.5" rx="1.5" fill="#9a6a3a"></rect>
          <rect x="35" y="10.5" width="10.5" height="5.6" rx="1.6" fill="#5b6b7a"></rect>
        </g>
        <g class="zs-debris">
          <rect class="zs-chip zs-chip-a" x="41" y="32.5" width="2.6" height="2.6" rx="0.6" fill="#8a96a1"></rect>
          <rect class="zs-chip zs-chip-b" x="43.4" y="33.5" width="2" height="2" rx="0.5" fill="#b3bcc4"></rect>
          <path class="zs-chip zs-chip-c" d="M39.4 34l2-1.6 1.4 2z" fill="#76828e"></path>
        </g>
        <g class="zs-sparks">
          <path class="zs-spark zs-spk1" d="M44 28.5l1 1.8-1.9.1.95 1.8-2-.95-.2 1.9-1.05-1.7-1.8.75.95-1.9-1.8-.3 1.8-1.05Z" fill="#f6b73c"></path>
          <circle class="zs-spark zs-spk2" cx="46.4" cy="30.6" r="1.1" fill="#ffd36b"></circle>
          <circle class="zs-spark zs-spk3" cx="40.2" cy="29.2" r="0.9" fill="#ff9f4a"></circle>
        </g>
      </svg>
    </div>
  </div>

  <!-- sleep-track (scrubben) -->
  <div class="zs-track pointer-events-auto absolute inset-x-0 cursor-grab" style="bottom:46px;height:62px" title="Sleep om door de werkzaamheden te scrubben"></div>
</div>

<style>
  @keyframes zs-hammer { 0%, 100% { transform: rotate(-24deg); } 45%, 55% { transform: rotate(16deg); } }
  @keyframes zs-spark { 0%, 42% { opacity: 0; transform: scale(0.6); } 52% { opacity: 1; transform: scale(1); } 72%, 100% { opacity: 0; transform: scale(1.1); } }
  @keyframes zs-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-2px); } }
  @keyframes zs-chip-a { 0%, 46% { opacity: 0; transform: translate(0, 0) rotate(0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(6px, -10px) rotate(50deg); } }
  @keyframes zs-chip-b { 0%, 46% { opacity: 0; transform: translate(0, 0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(8px, -6px) rotate(-40deg); } }
  @keyframes zs-chip-c { 0%, 46% { opacity: 0; transform: translate(0, 0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(-4px, -8px) rotate(45deg); } }
  @keyframes zs-dust { 0% { opacity: 0; transform: translate(0, 0) scale(0.5); } 40% { opacity: 0.5; } 100% { opacity: 0; transform: translate(-12px, -4px) scale(1.3); } }
  @keyframes zs-hook { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(3px); } }
  @keyframes zs-conf-fall { 0% { opacity: 1; transform: translateY(0) translateX(0) rotate(0); } 100% { opacity: 0; transform: translateY(64px) translateX(var(--dx, 0)) rotate(var(--r, 180deg)); } }

  .zs-worker-bob { animation: zs-bob 1.2s ease-in-out infinite; }
  .zs-worker .zs-arm { transform-box: fill-box; transform-origin: 6% 55%; animation: zs-hammer 1.2s ease-in-out infinite; }
  .zs-worker .zs-spark, .zs-worker .zs-chip { opacity: 0; transform-box: fill-box; transform-origin: center; }
  .zs-worker .zs-spark { animation: zs-spark 1.2s ease-in-out infinite; }
  .zs-worker .zs-spk2 { animation-delay: 0.05s; }
  .zs-worker .zs-spk3 { animation-delay: -0.04s; }
  .zs-worker .zs-chip { animation: zs-chip-a 1.2s ease-in-out infinite; }
  .zs-worker .zs-chip-b { animation-name: zs-chip-b; }
  .zs-worker .zs-chip-c { animation-name: zs-chip-c; }

  .zs-dust span { position: absolute; bottom: 0; left: 0; width: 7px; height: 7px; border-radius: 9999px; background: #cdbfa6; opacity: 0; animation: zs-dust 1.1s ease-out infinite; }
  .zs-dust span:nth-child(2) { animation-delay: 0.35s; left: -4px; }
  .zs-dust span:nth-child(3) { animation-delay: 0.7s; left: -8px; }

  .zs-crane .zs-hook { transform-box: fill-box; transform-origin: center; animation: zs-hook 2.4s ease-in-out infinite; }

  .zs-flag-cloth, .zs-flag-pole { transition: fill 0.4s ease; }
  .zs-flag { transition: transform 0.4s var(--ease-spring, ease); }
  .zs-flag.passed { transform: translate(-50%, -3px); }
  .zs-flag.passed .zs-flag-cloth { fill: #fb6b49; }
  .zs-flag.passed .zs-flag-pole { fill: #114c7f; }

  .zs-worker, .zs-daylabel { transition: left 0.4s linear, bottom 0.4s linear; }
  .zs-daylabel::after { content: ''; position: absolute; left: 50%; bottom: -4px; width: 8px; height: 8px; background: #fff; transform: translateX(-50%) rotate(45deg); box-shadow: 1px 1px 0 rgba(11, 36, 54, 0.06); }
  .zs-built { transition: stroke-dashoffset 0.4s var(--ease-out-quart, ease); }

  .zs-car { opacity: 0; }
  .zs-reopen { opacity: 0; transform: translateY(8px) scale(0.85); transition: opacity 0.4s var(--ease-spring, ease), transform 0.4s var(--ease-spring, ease); }
  .zs-reopen.show { opacity: 1; transform: translateY(0) scale(1); }
  .zs-conf { position: absolute; width: 6px; height: 9px; border-radius: 1px; opacity: 0; animation: zs-conf-fall 1.6s ease-in forwards; }

  .zs-track { touch-action: none; }
  .zs-track:active { cursor: grabbing; }

  .zs-qcar { transition: left 0.45s linear, bottom 0.45s linear, opacity 0.3s ease; }
  .zs-qcar svg { display: block; position: relative; z-index: 1; animation: zs-idle 1.7s ease-in-out infinite; }
  .zs-qcar:nth-child(3n) svg { animation-delay: 0.2s; }
  .zs-qcar:nth-child(3n + 1) svg { animation-delay: 0.55s; }
  .zs-qcar:nth-child(3n + 2) svg { animation-delay: 0.85s; }
  .zs-smoke { position: absolute; left: -2px; bottom: 3px; width: 5px; height: 5px; border-radius: 9999px; background: #5b6b7a; opacity: 0; animation: zs-smoke 1.8s ease-out infinite; }
  .zs-qcar:nth-child(3n) .zs-smoke { animation-delay: 0.3s; }
  .zs-qcar:nth-child(3n + 1) .zs-smoke { animation-delay: 0.9s; }
  .zs-qcar:nth-child(3n + 2) .zs-smoke { animation-delay: 1.3s; }
  @keyframes zs-idle { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-1px); } }
  @keyframes zs-smoke { 0% { opacity: 0; transform: translate(0, 0) scale(0.4); } 25% { opacity: 0.32; } 100% { opacity: 0; transform: translate(-9px, -13px) scale(1.6); } }

  @media (prefers-reduced-motion: reduce) {
    .zs-worker-bob, .zs-worker .zs-arm, .zs-worker .zs-spark, .zs-worker .zs-chip, .zs-dust span, .zs-crane .zs-hook, .zs-qcar svg, .zs-smoke { animation: none; }
    .zs-worker .zs-spark, .zs-worker .zs-chip, .zs-dust span, .zs-smoke { opacity: 0; }
  }
</style>

<script>
  const CLOSE_START = new Date('2027-01-01T00:00:00').getTime();
  const CLOSE_END = new Date('2027-05-01T00:00:00').getTime();
  const DAYS = 120;
  const clamp = (v: number) => Math.max(0, Math.min(1, v));
  const now = Date.now();
  let p = clamp((now - CLOSE_START) / (CLOSE_END - CLOSE_START));
  const ov = new URLSearchParams(window.location.search).get('tunnel');
  if (ov !== null) {
    const v = parseFloat(ov);
    if (!Number.isNaN(v)) p = clamp(v);
  }

  const VBW = 1440;
  const VBH = 130;
  const AQUA = '#2ed3c9';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const root = document.querySelector<HTMLElement>('.zs-build');
  const built = document.querySelector<SVGPathElement>('.zs-built');
  const worker = document.querySelector<HTMLElement>('.zs-worker');
  const dayLabel = document.querySelector<HTMLElement>('.zs-daylabel');
  const shoreStart = document.querySelector<HTMLElement>('.zs-shore-start');
  const shoreEnd = document.querySelector<HTMLElement>('.zs-shore-end');
  const flags = Array.from(document.querySelectorAll<HTMLElement>('.zs-flag'));
  const track = document.querySelector<HTMLElement>('.zs-track');
  const car = document.querySelector<HTMLElement>('.zs-car');
  const reopen = document.querySelector<HTMLElement>('.zs-reopen');
  const confetti = document.querySelector<HTMLElement>('.zs-confetti');
  const qcars = Array.from(document.querySelectorAll<HTMLElement>('.zs-qcar'));
  const QCOLORS = ['#e9522f', '#2479ba', '#5b6b7a', '#f6b73c', '#76828e', '#2ed3c9', '#0c9290'];
  qcars.forEach((c, i) => (c.style.color = QCOLORS[i % QCOLORS.length]));
  const QSP = 0.028;
  const len = built ? built.getTotalLength() : 0;

  const ptAt = (frac: number) => built!.getPointAtLength(len * clamp(frac));
  const place = (el: HTMLElement | null, frac: number, foot = 4) => {
    if (!el || !built) return;
    const pt = ptAt(frac);
    el.style.left = Math.max(1.5, (pt.x / VBW) * 100).toFixed(2) + '%';
    el.style.bottom = (VBH - pt.y + foot).toFixed(1) + 'px';
  };

  // vlaggetjes op de curve plaatsen
  flags.forEach((f) => place(f, Number(f.dataset.frac), 16));
  if (built) {
    place(shoreStart, 0, -2);
    place(shoreEnd, 1, -2);
  }

  let wasComplete = false;
  const applyAll = (frac: number, allowCelebrate = true) => {
    if (built) built.style.strokeDashoffset = String(100 * (1 - frac));
    place(worker, frac, 6);
    if (dayLabel) dayLabel.textContent = `Dag ${Math.round(frac * DAYS)} / ${DAYS} · ${Math.round(frac * 100)}%`;
    // opbouwende file achter de vakker
    const qn = frac >= 0.999 ? 0 : Math.round(Math.min(frac, 0.97) * qcars.length);
    qcars.forEach((c, i) => {
      const fi = frac - (i + 1) * QSP;
      if (i < qn && fi > 0.01) {
        place(c, fi, 2);
        c.style.opacity = '1';
      } else {
        c.style.opacity = '0';
      }
    });
    flags.forEach((f) => f.classList.toggle('passed', frac >= Number(f.dataset.frac) - 0.001));
    if (shoreEnd) {
      shoreEnd.classList.toggle('bg-ink/30', frac < 1);
      shoreEnd.style.background = frac >= 1 ? AQUA : '';
    }
    if (allowCelebrate && frac >= 0.999 && !wasComplete) celebrate();
    if (frac < 0.999) wasComplete = false;
  };

  function celebrate() {
    if (wasComplete) return;
    wasComplete = true;
    if (reduce) return;
    if (car) {
      car.style.transition = 'none';
      car.style.left = '-8%';
      car.style.opacity = '1';
      requestAnimationFrame(() => {
        car!.style.transition = 'left 1.5s cubic-bezier(0.4,0,0.2,1)';
        car!.style.left = '104%';
      });
      window.setTimeout(() => (car!.style.opacity = '0'), 1500);
    }
    if (reopen) {
      reopen.classList.add('show');
      window.setTimeout(() => reopen.classList.remove('show'), 2800);
    }
    if (confetti) {
      const cols = ['#2479ba', '#2ed3c9', '#fb6b49', '#f6b73c'];
      for (let i = 0; i < 16; i++) {
        const b = document.createElement('span');
        b.className = 'zs-conf';
        b.style.background = cols[i % cols.length];
        b.style.left = (78 + Math.random() * 20).toFixed(1) + '%';
        b.style.bottom = '92px';
        b.style.setProperty('--dx', (Math.random() * 44 - 22).toFixed(0) + 'px');
        b.style.setProperty('--r', (Math.random() * 540).toFixed(0) + 'deg');
        b.style.animationDelay = (Math.random() * 0.25).toFixed(2) + 's';
        confetti.appendChild(b);
        window.setTimeout(() => b.remove(), 2000);
      }
    }
  }

  // sleep-track: scrubben
  if (track && root) {
    let dragging = false;
    const setFromX = (clientX: number) => {
      const r = root.getBoundingClientRect();
      applyAll(clamp((clientX - r.left) / r.width));
    };
    track.addEventListener('pointerdown', (e) => {
      dragging = true;
      track.setPointerCapture(e.pointerId);
      setFromX(e.clientX);
    });
    track.addEventListener('pointermove', (e) => dragging && setFromX(e.clientX));
    const stop = () => (dragging = false);
    track.addEventListener('pointerup', stop);
    track.addEventListener('pointercancel', stop);
  }

  // start: intro-sweep daarna naar de datum-stand
  let first = true;
  try {
    first = !sessionStorage.getItem('zs_build_intro');
    sessionStorage.setItem('zs_build_intro', '1');
  } catch {}

  if (first && !reduce) {
    const dur = 1900;
    const t0 = performance.now();
    if (worker) worker.style.transition = 'none';
    const tick = (t: number) => {
      const k = Math.min(1, (t - t0) / dur);
      applyAll(1 - Math.pow(1 - k, 3), false);
      if (k < 1) requestAnimationFrame(tick);
      else {
        if (worker) worker.style.transition = '';
        requestAnimationFrame(() => applyAll(p));
      }
    };
    applyAll(0, false);
    requestAnimationFrame(tick);
  } else {
    applyAll(p);
  }
</script>
