---
// Hero-onderkant = tunnel-bouwtijdlijn die de golf-curve volgt (1 jan - 1 mei 2027).
// De golf IS de tunnelroute: gebouwd deel (gradient) vult achter een meelopende
// bouwvakker die de curve volgt; gepland deel lichtblauw; overkant licht aqua op.
const CREST = 'M0 72 C 320 38, 560 42, 760 66 S 1180 104, 1440 66';
const months = [
  { label: 'jan', left: 2 },
  { label: 'feb', left: 26.5 },
  { label: 'mrt', left: 51 },
  { label: 'apr', left: 75.5 },
  { label: 'mei', left: 98 },
];
---

<div class="zs-build pointer-events-none absolute inset-x-0 bottom-0 h-[150px]">
  <svg
    class="zs-build-svg absolute bottom-0 left-0 h-[150px] w-full"
    viewBox="0 0 1440 150"
    fill="none"
    preserveAspectRatio="none"
    aria-hidden="true"
    style="filter:drop-shadow(0 8px 18px rgba(18,130,176,0.22))"
  >
    <defs>
      <linearGradient id="zsBuildGrad" x1="0" y1="0" x2="1440" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#114c7f"></stop>
        <stop offset="0.5" stop-color="#2479ba"></stop>
        <stop offset="1" stop-color="#2ed3c9"></stop>
      </linearGradient>
    </defs>
    <!-- crème vlak onder de golf -->
    <path d={`${CREST} L1440 150 L0 150 Z`} fill="#f6f1e6"></path>
    <!-- geplande route -->
    <path d={CREST} stroke="#bcd7ee" stroke-width="20" stroke-linecap="round"></path>
    <!-- gebouwd deel -->
    <path
      class="zs-built"
      d={CREST}
      stroke="url(#zsBuildGrad)"
      stroke-width="20"
      stroke-linecap="round"
      pathLength="100"
      stroke-dasharray="100"
      stroke-dashoffset="100"
    ></path>
  </svg>

  <!-- oever-knopen (positie wordt gezet op de curve-uiteinden) -->
  <span class="zs-shore-start absolute h-4 w-4 rounded-full bg-sea-700 ring-4 ring-cream" style="left:1.5%;bottom:78px;transform:translate(-50%,50%)"></span>
  <span class="zs-shore-end absolute h-4 w-4 rounded-full bg-ink/30 ring-4 ring-cream" style="left:98.5%;bottom:84px;transform:translate(-50%,50%)"></span>

  <!-- maand-labels -->
  {
    months.map((m) => (
      <span class="absolute font-mono text-[11px] font-semibold text-mist" style={`left:${m.left}%;bottom:22px;transform:translateX(-50%)`}>
        {m.label}
      </span>
    ))
  }

  <!-- bouwvakker (HTML, volgt de curve) -->
  <div class="zs-worker absolute" style="left:9%;bottom:84px;transform:translateX(-50%)">
    <div class="zs-worker-bob">
      <svg width="58" height="68" viewBox="0 0 50 56" fill="none" aria-hidden="true">
        <ellipse cx="24" cy="54" rx="14" ry="2.6" fill="#0b2436" opacity="0.14"></ellipse>
        <!-- brokstenen / rubble -->
        <g>
          <path d="M31 54l2.6-3 2.6 3z" fill="#8a96a1"></path>
          <circle cx="39.5" cy="52.6" r="2.3" fill="#76828e"></circle>
          <path d="M42.5 54l2.4-2.3 2.4 2.3z" fill="#aab4bd"></path>
          <rect x="28.2" y="51.4" width="3" height="3" rx="0.8" fill="#94a0ab"></rect>
          <circle cx="35.5" cy="53.4" r="1.4" fill="#aab4bd"></circle>
        </g>
        <rect x="18" y="38" width="5" height="13" rx="2.5" fill="#114c7f"></rect>
        <rect x="25" y="38" width="5" height="13" rx="2.5" fill="#114c7f"></rect>
        <path d="M15.5 49H24v3a1 1 0 0 1-1 1h-6.5a1 1 0 0 1-1-1z" fill="#0b2436"></path>
        <path d="M24 49h8.5v3a1 1 0 0 1-1 1H25a1 1 0 0 1-1-1z" fill="#0b2436"></path>
        <rect x="15" y="22" width="18" height="19" rx="6" fill="#2479ba"></rect>
        <rect x="21" y="22" width="6" height="19" fill="#2ed3c9"></rect>
        <circle cx="24" cy="15" r="6.2" fill="#f2c6a0"></circle>
        <path d="M15.5 13a8.5 8.5 0 0 1 17 0Z" fill="#fb6b49"></path>
        <rect x="13.5" y="11.6" width="21" height="3.2" rx="1.6" fill="#e9522f"></rect>
        <rect x="23" y="5.6" width="2" height="3" rx="1" fill="#e9522f"></rect>
        <g class="zs-arm">
          <rect x="30" y="25" width="10" height="4.5" rx="2.25" fill="#f2c6a0"></rect>
          <rect x="38.5" y="13.5" width="3.4" height="15.5" rx="1.5" fill="#9a6a3a"></rect>
          <rect x="35" y="10.5" width="10.5" height="5.6" rx="1.6" fill="#5b6b7a"></rect>
        </g>
        <!-- wegspringende splinters -->
        <g class="zs-debris">
          <rect class="zs-chip zs-chip-a" x="41" y="32.5" width="2.6" height="2.6" rx="0.6" fill="#8a96a1"></rect>
          <rect class="zs-chip zs-chip-b" x="43.4" y="33.5" width="2" height="2" rx="0.5" fill="#b3bcc4"></rect>
          <path class="zs-chip zs-chip-c" d="M39.4 34l2-1.6 1.4 2z" fill="#76828e"></path>
        </g>
        <!-- vonken -->
        <g class="zs-sparks">
          <path class="zs-spark zs-spk1" d="M44 28.5l1 1.8-1.9.1.95 1.8-2-.95-.2 1.9-1.05-1.7-1.8.75.95-1.9-1.8-.3 1.8-1.05Z" fill="#f6b73c"></path>
          <circle class="zs-spark zs-spk2" cx="46.4" cy="30.6" r="1.1" fill="#ffd36b"></circle>
          <circle class="zs-spark zs-spk3" cx="40.2" cy="29.2" r="0.9" fill="#ff9f4a"></circle>
        </g>
      </svg>
    </div>
  </div>
</div>

<style>
  @keyframes zs-hammer {
    0%, 100% { transform: rotate(-24deg); }
    45%, 55% { transform: rotate(16deg); }
  }
  @keyframes zs-spark {
    0%, 42% { opacity: 0; transform: scale(0.6); }
    52% { opacity: 1; transform: scale(1); }
    72%, 100% { opacity: 0; transform: scale(1.1); }
  }
  @keyframes zs-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }
  .zs-worker { transition: left 0.4s linear, bottom 0.4s linear; }
  .zs-worker-bob { animation: zs-bob 1.2s ease-in-out infinite; }
  .zs-worker .zs-arm { transform-box: fill-box; transform-origin: 6% 55%; animation: zs-hammer 1.2s ease-in-out infinite; }
  .zs-worker .zs-spark, .zs-worker .zs-chip { opacity: 0; transform-box: fill-box; transform-origin: center; }
  .zs-worker .zs-spark { animation: zs-spark 1.2s ease-in-out infinite; }
  .zs-worker .zs-spk2 { animation-delay: 0.05s; }
  .zs-worker .zs-spk3 { animation-delay: -0.04s; }
  .zs-worker .zs-chip { animation: zs-chip-a 1.2s ease-in-out infinite; }
  .zs-worker .zs-chip-b { animation-name: zs-chip-b; }
  .zs-worker .zs-chip-c { animation-name: zs-chip-c; }
  @keyframes zs-chip-a { 0%, 46% { opacity: 0; transform: translate(0, 0) rotate(0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(6px, -10px) rotate(50deg); } }
  @keyframes zs-chip-b { 0%, 46% { opacity: 0; transform: translate(0, 0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(8px, -6px) rotate(-40deg); } }
  @keyframes zs-chip-c { 0%, 46% { opacity: 0; transform: translate(0, 0); } 56% { opacity: 1; } 100% { opacity: 0; transform: translate(-4px, -8px) rotate(45deg); } }
  .zs-built { transition: stroke-dashoffset 0.5s var(--ease-out-quart, ease); }
  @media (prefers-reduced-motion: reduce) {
    .zs-worker-bob, .zs-worker .zs-arm { animation: none; }
    .zs-worker .zs-spark, .zs-worker .zs-chip { animation: none; opacity: 0; }
  }
</style>

<script>
  const CLOSE_START = new Date('2027-01-01T00:00:00').getTime();
  const CLOSE_END = new Date('2027-05-01T00:00:00').getTime();
  const clamp = (v: number) => Math.max(0, Math.min(1, v));
  const now = Date.now();
  let p = clamp((now - CLOSE_START) / (CLOSE_END - CLOSE_START));

  const ov = new URLSearchParams(window.location.search).get('tunnel');
  if (ov !== null) {
    const v = parseFloat(ov);
    if (!Number.isNaN(v)) p = clamp(v);
  }

  // minimum-stand zodat de bouwvakker ook op dag 1 duidelijk in beeld staat
  const restFrac = Math.max(p, 0.09);

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const built = document.querySelector<SVGPathElement>('.zs-built');
  const worker = document.querySelector<HTMLElement>('.zs-worker');
  const shoreStart = document.querySelector<HTMLElement>('.zs-shore-start');
  const shoreEnd = document.querySelector<HTMLElement>('.zs-shore-end');
  const VBW = 1440;
  const VBH = 150;
  const len = built ? built.getTotalLength() : 0;

  const placeOnCurve = (el: HTMLElement | null, frac: number, footOffset = 4) => {
    if (!el || !built) return;
    const pt = built.getPointAtLength(len * clamp(frac));
    el.style.left = ((pt.x / VBW) * 100).toFixed(2) + '%';
    el.style.bottom = (VBH - pt.y + footOffset).toFixed(1) + 'px';
  };

  // oevers op de curve-uiteinden
  if (built) {
    placeOnCurve(shoreStart, 0, -2);
    placeOnCurve(shoreEnd, 1, -2);
  }

  const apply = (frac: number) => {
    if (built) built.style.strokeDashoffset = String(100 * (1 - frac));
    placeOnCurve(worker, frac, 6);
  };

  if (shoreEnd && p >= 1) {
    shoreEnd.classList.remove('bg-ink/30');
    shoreEnd.classList.add('bg-aqua-500');
  }

  let first = true;
  try {
    first = !sessionStorage.getItem('zs_build_intro');
    sessionStorage.setItem('zs_build_intro', '1');
  } catch {}

  if (first && !reduce) {
    const dur = 1900;
    const t0 = performance.now();
    if (worker) worker.style.transition = 'none';
    const tick = (t: number) => {
      const k = Math.min(1, (t - t0) / dur);
      const e = 1 - Math.pow(1 - k, 3);
      apply(e);
      if (k < 1) requestAnimationFrame(tick);
      else {
        if (worker) worker.style.transition = 'left 0.8s var(--ease-out-quart, ease), bottom 0.8s var(--ease-out-quart, ease)';
        requestAnimationFrame(() => apply(restFrac));
      }
    };
    apply(0);
    requestAnimationFrame(tick);
  } else {
    apply(restFrac);
  }
</script>
