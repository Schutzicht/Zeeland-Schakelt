---
import { ICONS } from '../lib/icons';

interface Props {
  name: string;
  size?: number;
  stroke?: number;
  class?: string;
}

const { name, size = 24, stroke = 1.7, class: cls = '' } = Astro.props;
const inner = ICONS[name] ?? '';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
  set:html={inner}
/>
