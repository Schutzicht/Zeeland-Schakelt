---
import { ICONS } from '../lib/icons';

interface Props {
  name: string;
  size?: number;
  stroke?: number; // genegeerd (Phosphor-gewicht zit in het icoon)
  class?: string;
}

const { name, size = 24, class: cls = '' } = Astro.props;
const inner = ICONS[name] ?? '';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 256 256"
  fill="currentColor"
  class={cls}
  aria-hidden="true"
  set:html={inner}
/>
